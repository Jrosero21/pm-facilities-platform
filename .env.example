# PM Facilities Platform — environment variables (example)
# Copy this file to `.env.local` and fill in real values. `.env.local` is gitignored.

# --- Database ----------------------------------------------------------------
# MySQL/MariaDB on Namecheap, reached via a local SSH tunnel.
# Start the tunnel in a separate terminal before running `pnpm dev`:
#
#   ssh -p 21098 -L 3307:127.0.0.1:3306 jonnyrosero@host62.registrar-servers.com
#
# URL-encode the password if it contains special characters (e.g. @, :, /, ?).
DATABASE_URL=mysql://jonnyrosero_jonny:REPLACE_ME@127.0.0.1:3307/jonnyrosero_pm
