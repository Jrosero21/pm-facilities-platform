{
  "name": "pm-facilities-platform",
  "version": "0.2.0-phase-1",
  "private": true,
  "description": "Multi-tenant facilities maintenance and project management platform.",
  "type": "module",
  "packageManager": "pnpm@11.3.0",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "db:generate": "drizzle-kit generate && node scripts/fix-mysql-engine.mjs && node scripts/check-migration-identifiers.mjs",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "db:seed": "tsx --env-file=.env.local db/seeds/initial.ts",
    "db:seed:trades": "tsx --env-file=.env.local db/seeds/trades.ts",
    "db:seed:job-reference": "tsx --env-file=.env.local db/seeds/job-reference.ts",
    "db:seed:dispatch-reference": "tsx --env-file=.env.local db/seeds/dispatch-reference.ts",
    "db:seed:agent-config": "tsx --env-file=.env.local db/seeds/agent-config.ts",
    "db:check:analytics-readers": "tsx --env-file=.env.local --conditions=react-server scripts/check-analytics-readers.ts",
    "db:check:vendor-predicates": "tsx --env-file=.env.local --conditions=react-server scripts/check-vendor-predicates.ts",
    "db:check:client-portal": "tsx --env-file=.env.local --conditions=react-server scripts/check-client-portal.ts",
    "db:check:external-integrations": "tsx --env-file=.env.local --conditions=react-server scripts/check-external-integrations.ts",
    "db:check:email-ingestion": "tsx --env-file=.env.local --conditions=react-server scripts/check-email-ingestion.ts",
    "db:check:pm-generation": "tsx --env-file=.env.local --conditions=react-server scripts/check-pm-generation.ts",
    "db:check:snow-dispatch": "tsx --env-file=.env.local --conditions=react-server scripts/check-snow-dispatch.ts",
    "db:check:chatbot-assistant": "tsx --env-file=.env.local --conditions=react-server scripts/check-chatbot-assistant.ts",
    "db:check:operator-review": "tsx --env-file=.env.local --conditions=react-server scripts/check-operator-review.ts",
    "db:check:notifications-send": "tsx --env-file=.env.local --conditions=react-server scripts/check-notifications-send.ts",
    "db:check:vendor-edge": "tsx --env-file=.env.local --conditions=react-server scripts/check-phase-20.ts",
    "db:check:magic-link": "tsx --env-file=.env.local --conditions=react-server scripts/check-phase-21.ts",
    "db:check:dispatch": "tsx --env-file=.env.local --conditions=react-server scripts/check-phase-22.ts",
    "db:check:autonomy": "tsx --env-file=.env.local --conditions=react-server scripts/check-phase-23.ts",
    "db:retention:agent-payloads": "tsx --env-file=.env.local --conditions=react-server scripts/retention-agent-payloads.ts",
    "db:check:observability": "tsx --env-file=.env.local --conditions=react-server scripts/check-phase-24.ts",
    "db:check:feedback": "tsx --env-file=.env.local --conditions=react-server scripts/check-phase-25.ts",
    "db:check:invoice": "tsx --env-file=.env.local --conditions=react-server scripts/check-phase-26.ts",
    "db:check:proposal": "tsx --env-file=.env.local --conditions=react-server scripts/check-phase-27.ts",
    "db:check:job-edit": "tsx --env-file=.env.local --conditions=react-server scripts/check-job-edit.ts",
    "db:check:billing-rules": "tsx --env-file=.env.local --conditions=react-server scripts/check-billing-rules.ts",
    "db:check:client-rates": "tsx --env-file=.env.local --conditions=react-server scripts/check-client-rates.ts",
    "db:check:billing-from-rates": "tsx --env-file=.env.local --conditions=react-server scripts/check-billing-from-rates.ts",
    "db:check:proposal-rate-prefill": "tsx --env-file=.env.local --conditions=react-server scripts/check-proposal-rate-prefill.ts",
    "db:check:invoice-rate-sheet": "tsx --env-file=.env.local --conditions=react-server scripts/check-invoice-rate-sheet.ts",
    "db:check:vendor-invoice-documents": "tsx --env-file=.env.local --conditions=react-server scripts/check-vendor-invoice-documents.ts"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.79",
    "@ai-sdk/openai": "^3.0.67",
    "@aws-sdk/client-s3": "^3.1057.0",
    "@aws-sdk/s3-request-presigner": "^3.1057.0",
    "ai": "^6.0.191",
    "better-auth": "^1.6.11",
    "big.js": "^7.0.1",
    "date-fns": "^4.4.0",
    "drizzle-orm": "^0.45.2",
    "mysql2": "^3.22.3",
    "next": "^16.2.6",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "server-only": "^0.0.1",
    "uuid": "^14.0.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.3.0",
    "@types/big.js": "^7.0.0",
    "@types/node": "^25.9.1",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "dotenv": "^17.4.2",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.6",
    "postcss": "^8.5.15",
    "prettier": "^3.8.3",
    "tailwindcss": "^4.3.0",
    "tsx": "^4.22.3",
    "typescript": "^6.0.3"
  }
}
